#!/usr/bin/env bash
# shellcheck disable=1091

#----- General environment

export LANG="en_US.UTF-8"
export LC_CTYPE="$LANG"
export LC_ALL="$LANG"
export COLORTERM=truecolor

# XDG directories
export XDG_CONFIG_HOME="$HOME/.config"
export  XDG_CACHE_HOME="$HOME/.cache"
export   XDG_DATA_HOME="$HOME/.local/share"
export  XDG_STATE_HOME="$HOME/.local/state"

[ -d "$XDG_CONFIG_HOME" ] || mkdir -m 0750 "$XDG_CONFIG_HOME"
[ -d "$XDG_CACHE_HOME" ]  || mkdir -m 0750 "$XDG_CACHE_HOME"
[ -d "$XDG_DATA_HOME" ]   || mkdir -m 0750 "$XDG_DATA_HOME"
[ -d "$XDG_STATE_HOME" ]  || mkdir -m 0750 "$XDG_STATE_HOME"

# Gnupg stuff
export GNUPGHOME="$HOME/.local/share/gnupg"


#----- PATH Binaries

# from /etc/profile
append_path () {
	case ":$PATH:" in
		*:"$1":*) ;;
		*) PATH="${PATH:+$PATH:}$1"
	esac
}

# Local binaries path
append_path "$HOME/.local/bin"

# dot_server binaries
if [[ "$OSTYPE" == "freebsd"* ]]; then
	append_path "$HOME/.config/bin/freeBSD"
fi

if [[ "$OSTYPE" == "linux-gnu"* ]]; then
  ARCH="$(lscpu | grep 'Architecture' | cut -d ':' -f 2)"
  ARCH="${ARCH#"${ARCH%%[![:space:]]*}"}"

  case "$ARCH" in
    x86_64) ARCH="amd64" ;;
    aarch64) ARCH="arm64" ;;
    *) ARCH="amd64" ;;
  esac

	# adds .config/bin folder to PATH
	append_path "$HOME/.config/bin/linux_${ARCH}"
fi


#----- Terminal utilities

# https://www.gnu.org/software/bash/manual/html_node/Readline-Init-File.html
export INPUTRC="$XDG_CONFIG_HOME/bash/inputrc"

# History settings
export HISTSIZE=20000
if [[ "$BASH" ]]; then
	export HISTFILE="$XDG_CACHE_HOME/bash_history"
	export HISTFILESIZE=15000000
	export HISTTIMEFORMAT="%F %T "
	export HISTIGNORE='pwd:jobs:ls:history:clear:r:lf'
	export HISTCONTROL=ignoreboth
fi

# Pager and Editor
export PAGER=/usr/bin/less
MANPAGER=$PAGER

if hash vim 2> /dev/null; then
	if [[ "$OSTYPE" == "freebsd"* ]]; then
		export EDITOR=/usr/local/bin/vim
	fi
	if [[ "$OSTYPE" == "linux-gnu"* ]]; then
		export EDITOR=/usr/bin/vim
		export SYSTEMD_EDITOR=$EDITOR
	fi
  export SUDO_EDITOR=$EDITOR
	export SELECTED_EDITOR=$EDITOR
	export VISUAL=$EDITOR
	MANPAGER='vim +MANPAGER --not-a-term -'
fi

export MANPAGER
export MANWIDTH=999
export LESS="-FiQMXRwJ --incsearch --no-vbell --status-col-width 1"
export LESSQUIET=1
export LESSCHARSET="UTF-8"
export LESSHISTFILE="$XDG_CACHE_HOME/less_history"

# Wget stuff
if [ -f "$XDG_CONFIG_HOME/wget/wgetrc" ]; then
	export WGETRC="$XDG_CONFIG_HOME/wget/wgetrc"
fi

# enable network connection forwarding, see route_fwd.sh
export FORWARDING=0
export IS_FORWARDING=0

if hash sysctl 2> /dev/null; then
	FORWARDING=$(sysctl net.ipv4.ip_forward | sed -E 's/.*= //g')
	if [ "$FORWARDING" -eq 1 ]; then
		[ "$IS_FORWARDING" -eq 0 ] && {
			bash -c "$XDG_CONFIG_HOME/route_fwd.sh"
			IS_FORWARDING=1
		}
	fi
fi

if ! export -p | grep -q XDG_RUNTIME_DIR=; then
  XDG_RUNTIME_DIR="/run/user/$(id -u "$USER")"
  export XDG_RUNTIME_DIR
fi

#----- Utilities

# docker rootless config
export DOCKER_CONFIG="${XDG_CONFIG_HOME}"/docker
export DOCKER_BIN="$HOME/.local/docker_bin"
append_path "$DOCKER_BIN"

if hash docker 2> /dev/null; then
	export DOCKER_HOST=unix://${XDG_RUNTIME_DIR}/docker.sock
	export DOCKERD_ROOTLESS_ROOTLESSKIT_FLAGS="-p 0.0.0.0:2376:2376/tcp"
fi

# Go config
if hash go 2> /dev/null; then
	export GOPATH="$XDG_DATA_HOME/go"
	append_path "$GOPATH/bin"
fi

# python
export PYTHON_COLORS=1
export PYTHONUSERBASE="$XDG_DATA_HOME/python"
export PYTHON_HISTORY="$XDG_STATE_HOME/python/history"
export PYTHONPYCACHEPREFIX="$XDG_CACHE_HOME/python"

if hash pipx 2> /dev/null; then
	export PIPX_HOME="$XDG_DATA_HOME/python/pipx"
	export PIPX_BIN_DIR="$XDG_DATA_HOME/python/pipx/bin"
	append_path "$PIPX_BIN_DIR"
fi

# Unload our profile API functions
unset -f append_path

# Export the final PATH
export PATH

